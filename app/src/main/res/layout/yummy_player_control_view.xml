<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <View
        android:id="@id/exo_controls_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#99000000" />

    <LinearLayout
        android:id="@+id/yummy_player_top_bar"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_gravity="top"
        android:background="#B3000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="18dp">

        <ImageButton
            android:id="@+id/yummy_player_back"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/player_control_chip"
            android:clickable="true"
            android:contentDescription="@string/player_back"
            android:focusable="true"
            android:padding="14dp"
            android:scaleType="center"
            android:src="@drawable/ic_player_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/yummy_player_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/yummy_player_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/yummy_player_episode_controls"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:clipChildren="false"
        android:clipToPadding="false">

        <TextView
            android:id="@+id/yummy_episode_previous"
            android:layout_width="116dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:background="@drawable/player_control_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/player_previous"
            android:textColor="#FF10141F"
            android:textSize="17sp"
            android:textStyle="bold"
            android:translationX="-108dp" />

        <FrameLayout
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_gravity="center">

            <ImageButton
                android:id="@id/exo_play_pause"
                style="@style/ExoStyledControls.Button.Center.PlayPause"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_gravity="center"
                android:background="@drawable/player_control_chip"
                android:contentDescription="@string/player_play_pause" />
        </FrameLayout>

        <TextView
            android:id="@+id/yummy_episode_next"
            android:layout_width="116dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:background="@drawable/player_control_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/player_next"
            android:textColor="#FF10141F"
            android:textSize="17sp"
            android:textStyle="bold"
            android:translationX="108dp" />
    </FrameLayout>

    <LinearLayout
        android:id="@id/exo_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="148dp"
        android:layout_gravity="bottom"
        android:background="#D9000000"
        android:gravity="top"
        android:layoutDirection="ltr"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingTop="2dp"
        android:paddingEnd="6dp"
        android:paddingBottom="12dp">

        <View
            android:id="@id/exo_progress_placeholder"
            android:layout_width="match_parent"
            android:layout_height="@dimen/yummy_player_progress_height" />

        <LinearLayout
            android:id="@+id/yummy_player_bottom_content"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/yummy_player_bottom_start"
                android:layout_width="68dp"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="0dp"
                android:paddingEnd="4dp">

                <LinearLayout
                    android:id="@id/exo_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:importantForAccessibility="noHideDescendants"
                    android:layoutDirection="ltr"
                    android:orientation="vertical">

                    <TextView
                        android:id="@id/exo_position"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="sans"
                        android:gravity="start"
                        android:includeFontPadding="false"
                        android:letterSpacing="0"
                        android:maxLines="1"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        android:textAlignment="viewStart"
                        android:textColor="#FFFFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@id/exo_duration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="sans"
                        android:gravity="start"
                        android:includeFontPadding="false"
                        android:letterSpacing="0"
                        android:maxLines="1"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        android:textAlignment="viewStart"
                        android:textColor="#CCFFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/yummy_player_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans"
                    android:gravity="start"
                    android:includeFontPadding="false"
                    android:letterSpacing="0"
                    android:maxLines="1"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:textAlignment="viewStart"
                    android:textColor="#CCFFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@id/exo_basic_controls"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageButton
                    android:id="@id/exo_settings"
                    style="@style/ExoStyledControls.Button.Bottom.Settings"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/yummy_player_action_row"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:baselineAligned="false"
                android:gravity="center_vertical|end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/yummy_player_voice"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1.12"
                    android:autoSizeMaxTextSize="13sp"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeStepGranularity="1sp"
                    android:autoSizeTextType="uniform"
                    android:background="@drawable/player_control_chip"
                    android:clickable="true"
                    android:contentDescription="@string/player_voice"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:gravity="center"
                    android:maxLines="1"
                    android:minWidth="0dp"
                    android:text="@string/player_voice"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/yummy_player_quality"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1.22"
                    android:autoSizeMaxTextSize="13sp"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeStepGranularity="1sp"
                    android:autoSizeTextType="uniform"
                    android:background="@drawable/player_control_chip"
                    android:clickable="true"
                    android:contentDescription="@string/player_quality"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:gravity="center"
                    android:maxLines="1"
                    android:minWidth="0dp"
                    android:text="@string/player_quality"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/yummy_player_volume"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="0.82"
                    android:autoSizeMaxTextSize="13sp"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeStepGranularity="1sp"
                    android:autoSizeTextType="uniform"
                    android:background="@drawable/player_control_chip"
                    android:clickable="true"
                    android:contentDescription="@string/player_volume"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:gravity="center"
                    android:maxLines="1"
                    android:minWidth="0dp"
                    android:text="@string/player_volume"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/yummy_player_pip"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="0.82"
                    android:autoSizeMaxTextSize="13sp"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeStepGranularity="1sp"
                    android:autoSizeTextType="uniform"
                    android:background="@drawable/player_control_chip"
                    android:clickable="true"
                    android:contentDescription="@string/player_pip"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:gravity="center"
                    android:maxLines="1"
                    android:minWidth="0dp"
                    android:text="@string/player_pip"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</merge>
